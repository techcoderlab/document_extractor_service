# ─────────────────────────────────────────────────────
# Module   : .env.example
# Layer    : Infrastructure / Configuration
# Pillar   : P2 (Security)
# Complexity: O(1) time, O(1) space
# ─────────────────────────────────────────────────────

# P2 (Security): NEVER commit the actual .env file to version control.
# Copy this file to .env and populate with real credentials.

# ── Discord ────────────────────────────────────────────────────
DISCORD_BOT_TOKEN="your_discord_bot_token_here"
DISCORD_WATCH_CHANNEL_ID="123456789012345678"

# ── API / Web ──────────────────────────────────────────────────
API_BASE_URL="http://localhost:8000"
API_SECRET_KEY="generate_a_secure_random_string_here"

# ── LLM Providers ──────────────────────────────────────────────
DEFAULT_PROVIDER="gemini"
DEFAULT_MODEL="gemini-2.0-flash"

GOOGLE_GEMINI_API_KEY="your_gemini_api_key_here"
# OPENAI_API_KEY=""
# ANTHROPIC_API_KEY=""

# ── Google Sheets ──────────────────────────────────────────────
# Base64 encoded JSON contents of your Google Service Account key file.
# Command to encode: `cat credentials.json | base64 -w 0` (Linux) or `base64 -i credentials.json` (Mac)
GOOGLE_SERVICE_ACCOUNT_B64=""
GOOGLE_SPREADSHEET_ID="your_spreadsheet_id_here"

# ── Observability ──────────────────────────────────────────────
LOG_LEVEL="INFO"